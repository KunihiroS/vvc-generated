---
import { getCollection } from "astro:content";

const entries = (await getCollection("slides"))
  .map((entry) => {
    const archiveDate = entry.data.generatedAt ?? entry.data.pubDate;
    return {
      id: entry.id,
      ...entry.data,
      archiveDate,
      month: archiveDate.toISOString().slice(0, 7),
      archiveTime: archiveDate.getTime(),
    };
  })
  .sort((a, b) => b.archiveTime - a.archiveTime || a.title.localeCompare(b.title));
const months = Array.from(new Set(entries.map((entry) => entry.month))).sort((a, b) => b.localeCompare(a));
const totalDecks = entries.filter((entry) => entry.kind === "visual-summary-deck").length;
const totalSlides = entries.length - totalDecks;
const basePath = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const faviconHref = `${basePath}favicon.svg`;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tech info slides</title>
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <style>
      :root {
        color-scheme: dark;
        --bg: #1c1814;
        --bg-soft: #241f1a;
        --fg: #f4eadb;
        --title: #fff5e6;
        --muted: #c9b9a3;
        --line: #45382b;
        --line-strong: #6a523c;
        --card: #2a231d;
        --card-raised: #332a22;
        --accent: #d6a05f;
        --accent-soft: #7a5532;
        --accent-text: #1c1814;
        --poster-bg: #fffaf2;
        --poster-ink: #3a2b20;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-width: 320px;
        font-family: Inter, "Noto Sans JP", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--fg);
        background:
          linear-gradient(180deg, rgba(214, 160, 95, .08), rgba(214, 160, 95, 0) 280px),
          var(--bg);
      }

      main {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
        padding: 34px 0 64px;
      }

      header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: end;
        gap: 22px;
        padding: 18px 0 28px;
        border-bottom: 1px solid var(--line);
      }

      h1 {
        margin: 0;
        max-width: 780px;
        font-family: "Times New Roman", "Noto Serif JP", "Yu Mincho", serif;
        font-size: clamp(3rem, 8vw, 7.2rem);
        font-weight: 700;
        line-height: .86;
        letter-spacing: 0;
        color: var(--title);
      }

      .summary {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 8px;
        max-width: 360px;
        color: var(--muted);
        font-size: .88rem;
      }

      .summary span,
      .chip,
      .kind {
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0 10px;
        background: rgba(255, 250, 242, .04);
      }

      .controls {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin: 22px 0 30px;
      }

      .control-group {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      button[data-month-filter],
      button[data-sort] {
        min-height: 36px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0 14px;
        background: var(--bg-soft);
        color: var(--muted);
        cursor: pointer;
        font: inherit;
      }

      button[data-month-filter]:hover,
      button[data-sort]:hover {
        border-color: var(--line-strong);
        color: var(--fg);
      }

      button[data-month-filter][aria-pressed="true"],
      button[data-sort][aria-pressed="true"] {
        background: var(--accent);
        border-color: var(--accent);
        color: var(--accent-text);
      }

      .archive-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 18px;
        align-items: stretch;
      }

      article[data-archive-card] {
        display: grid;
        grid-template-rows: auto 1fr;
        min-height: 100%;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--card);
      }

      article[data-archive-card][hidden] { display: none; }

      .poster {
        aspect-ratio: 16 / 10;
        width: 100%;
        border: 0;
        border-bottom: 1px solid var(--line);
        background: var(--poster-bg);
        object-fit: cover;
      }

      .poster.placeholder {
        display: grid;
        place-items: center;
        position: relative;
        overflow: hidden;
        color: var(--poster-ink);
        font-family: "Times New Roman", "Noto Serif JP", serif;
        font-size: 2rem;
        font-weight: 700;
      }

      .poster.placeholder::before {
        content: "";
        position: absolute;
        inset: 24px;
        border: 2px solid rgba(58, 43, 32, .24);
      }

      .poster.placeholder::after {
        content: "";
        position: absolute;
        width: 48%;
        height: 44%;
        border-top: 3px solid rgba(214, 160, 95, .7);
        border-bottom: 3px solid rgba(58, 43, 32, .18);
      }

      .card-body {
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-width: 0;
        padding: 16px;
      }

      h2 {
        margin: 0;
        font-size: 1.08rem;
        line-height: 1.34;
        letter-spacing: 0;
        color: var(--title);
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        color: var(--muted);
        font-size: .8rem;
      }

      .kind {
        color: var(--accent);
      }

      .summary-text {
        margin: 0;
        color: var(--muted);
        font-size: .92rem;
        line-height: 1.6;
      }

      .actions {
        margin-top: auto;
        padding-top: 4px;
      }

      a.open {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        border-radius: 6px;
        padding: 0 14px;
        background: var(--accent);
        color: var(--accent-text);
        font-weight: 700;
        text-decoration: none;
      }

      a.open:hover {
        background: #e6b879;
      }

      .empty {
        grid-column: 1 / -1;
        padding: 28px 0;
        color: var(--muted);
      }

      @media (max-width: 820px) {
        main { width: min(100% - 28px, 1180px); padding-top: 28px; }
        header { grid-template-columns: 1fr; align-items: start; }
        .summary { justify-content: flex-start; max-width: none; }
        .controls { justify-content: flex-start; }
      }

      @media (max-width: 560px) {
        main { width: min(100% - 24px, 1180px); padding-bottom: 44px; }
        h1 { font-size: clamp(2.7rem, 17vw, 4.8rem); }
        .archive-list { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>Tech info slides</h1>
        <div class="summary" aria-label="Archive summary">
          <span>{entries.length} entries</span>
          <span>{totalSlides} slides</span>
          <span>{totalDecks} visual summaries</span>
        </div>
      </header>

      <div class="controls" aria-label="Archive controls">
        <nav class="control-group" aria-label="Months">
          <button data-month-filter="all" aria-pressed="true">All months</button>
          {months.map((month) => <button data-month-filter={month} aria-pressed="false">{month}</button>)}
        </nav>
        <div class="control-group" aria-label="Sort order">
          <button data-sort="newest" aria-pressed="true">Newest</button>
          <button data-sort="oldest" aria-pressed="false">Oldest</button>
        </div>
      </div>

      <section class="archive-list" aria-live="polite">
        {entries.length === 0 && <p class="empty">No slides published yet.</p>}
        {entries.map((entry) => (
          <article data-archive-card data-month={entry.month} data-archive-time={entry.archiveTime}>
            {entry.thumbnailUrl ? <img class="poster" src={entry.thumbnailUrl} alt="" loading="lazy" /> : <div class="poster placeholder">HTML</div>}
            <div class="card-body">
              <h2>{entry.title}</h2>
              <div class="meta">
                <time datetime={entry.archiveDate.toISOString()}>{entry.archiveDate.toISOString().slice(0, 10)}</time>
                <span class="kind">{entry.kind === "visual-summary-deck" ? "Visual Summary" : "Slide"}</span>
                <span class="chip">{entry.month}</span>
              </div>
              {entry.summary && <p class="summary-text">{entry.summary}</p>}
              <div class="actions"><a class="open" href={entry.slideUrl} target="_blank" rel="noopener noreferrer">Open</a></div>
            </div>
          </article>
        ))}
      </section>
    </main>
    <script>
      const monthButtons = Array.from(document.querySelectorAll("[data-month-filter]"));
      const sortButtons = Array.from(document.querySelectorAll("[data-sort]"));
      const list = document.querySelector(".archive-list");
      const entries = Array.from(document.querySelectorAll("article[data-archive-card]"));
      let activeMonth = "all";
      let activeSort = "newest";

      function updateArchive() {
        const direction = activeSort === "oldest" ? 1 : -1;
        const sortedEntries = [...entries].sort((a, b) => {
          const aTime = Number(a.getAttribute("data-archive-time") || "0");
          const bTime = Number(b.getAttribute("data-archive-time") || "0");
          return direction * (aTime - bTime) || a.textContent.localeCompare(b.textContent);
        });
        for (const entry of sortedEntries) list?.append(entry);
        for (const entry of entries) {
          entry.hidden = activeMonth !== "all" && entry.getAttribute("data-month") !== activeMonth;
        }
      }

      for (const button of monthButtons) {
        button.addEventListener("click", () => {
          activeMonth = button.getAttribute("data-month-filter") || "all";
          for (const item of monthButtons) item.setAttribute("aria-pressed", String(item === button));
          updateArchive();
        });
      }
      for (const button of sortButtons) {
        button.addEventListener("click", () => {
          activeSort = button.getAttribute("data-sort") || "newest";
          for (const item of sortButtons) item.setAttribute("aria-pressed", String(item === button));
          updateArchive();
        });
      }
    </script>
  </body>
</html>
