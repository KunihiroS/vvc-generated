---
import { getCollection } from "astro:content";

const entries = (await getCollection("slides"))
  .map((entry) => {
    const archiveDate = entry.data.generatedAt ?? entry.data.pubDate;
    return {
      id: entry.id,
      ...entry.data,
      archiveDate,
      month: archiveDate.toISOString().slice(0, 7),
      archiveTime: archiveDate.getTime(),
    };
  })
  .sort((a, b) => b.archiveTime - a.archiveTime || a.title.localeCompare(b.title));
const months = Array.from(new Set(entries.map((entry) => entry.month))).sort((a, b) => b.localeCompare(a));
const totalDecks = entries.filter((entry) => entry.kind === "visual-summary-deck").length;
const totalSlides = entries.length - totalDecks;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>VVC Slide Archive</title>
    <style>
      :root { color-scheme: light; --ink: #1d2433; --muted: #667085; --line: #d9dee8; --paper: #fbfcfe; --accent: #0f766e; --warm: #b45309; --soft: #eef6f4; }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: var(--ink); background: var(--paper); }
      main { max-width: 1120px; margin: 0 auto; padding: 32px 20px 56px; }
      header { display: grid; gap: 14px; padding: 8px 0 24px; border-bottom: 1px solid var(--line); }
      h1 { margin: 0; font-size: clamp(2rem, 6vw, 4.4rem); line-height: .94; letter-spacing: 0; }
      .summary { display: flex; flex-wrap: wrap; gap: 10px; color: var(--muted); font-size: .95rem; }
      .controls { display: grid; gap: 12px; margin: 22px 0 26px; }
      .control-group { display: flex; flex-wrap: wrap; gap: 8px; }
      button[data-month-filter], button[data-sort] { min-height: 36px; border: 1px solid var(--line); border-radius: 999px; padding: 0 14px; background: white; color: var(--ink); cursor: pointer; font: inherit; }
      button[data-month-filter][aria-pressed="true"], button[data-sort][aria-pressed="true"] { background: var(--ink); border-color: var(--ink); color: white; }
      .archive-list { display: grid; gap: 12px; }
      article { display: grid; grid-template-columns: minmax(0, 1fr) 172px; gap: 18px; align-items: stretch; padding: 16px; border: 1px solid var(--line); border-radius: 8px; background: white; }
      article[hidden] { display: none; }
      h2 { margin: 0; font-size: 1.1rem; line-height: 1.35; letter-spacing: 0; }
      .meta { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 8px; color: var(--muted); font-size: .86rem; }
      .chip { display: inline-flex; align-items: center; min-height: 24px; border-radius: 999px; padding: 0 9px; background: var(--soft); color: #115e59; }
      .kind { color: var(--warm); }
      .actions { margin-top: 14px; }
      a.open { display: inline-flex; align-items: center; justify-content: center; min-height: 36px; border-radius: 6px; padding: 0 12px; background: var(--accent); color: white; text-decoration: none; }
      .thumb { width: 100%; min-height: 96px; border-radius: 6px; border: 1px solid var(--line); background: #f4f6fa; object-fit: cover; }
      .thumb.placeholder { display: grid; place-items: center; color: var(--muted); font-size: .85rem; }
      .empty { padding: 28px 0; color: var(--muted); }
      @media (max-width: 720px) { main { padding-inline: 14px; } article { grid-template-columns: 1fr; } .thumb { max-height: 180px; } }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>VVC Slide Archive</h1>
        <div class="summary">
          <span>{entries.length} entries</span>
          <span>{totalSlides} slides</span>
          <span>{totalDecks} visual summaries</span>
        </div>
      </header>

      <div class="controls" aria-label="Archive controls">
        <nav class="control-group" aria-label="Months">
          <button data-month-filter="all" aria-pressed="true">All months</button>
          {months.map((month) => <button data-month-filter={month} aria-pressed="false">{month}</button>)}
        </nav>
        <div class="control-group" aria-label="Sort order">
          <button data-sort="newest" aria-pressed="true">Newest</button>
          <button data-sort="oldest" aria-pressed="false">Oldest</button>
        </div>
      </div>

      <section class="archive-list" aria-live="polite">
        {entries.length === 0 && <p class="empty">No slides published yet.</p>}
        {entries.map((entry) => (
          <article data-month={entry.month} data-archive-time={entry.archiveTime}>
            <div>
              <h2>{entry.title}</h2>
              <div class="meta">
                <time datetime={entry.archiveDate.toISOString()}>{entry.archiveDate.toISOString().slice(0, 10)}</time>
                <span class="kind">{entry.kind === "visual-summary-deck" ? "Visual Summary" : "Slide"}</span>
                <span class="chip">{entry.month}</span>
              </div>
              {entry.summary && <p>{entry.summary}</p>}
              <div class="actions"><a class="open" href={entry.slideUrl}>Open</a></div>
            </div>
            {entry.thumbnailUrl ? <img class="thumb" src={entry.thumbnailUrl} alt="" loading="lazy" /> : <div class="thumb placeholder">HTML</div>}
          </article>
        ))}
      </section>
    </main>
    <script>
      const monthButtons = Array.from(document.querySelectorAll("[data-month-filter]"));
      const sortButtons = Array.from(document.querySelectorAll("[data-sort]"));
      const list = document.querySelector(".archive-list");
      const entries = Array.from(document.querySelectorAll("article[data-month]"));
      let activeMonth = "all";
      let activeSort = "newest";

      function updateArchive() {
        const direction = activeSort === "oldest" ? 1 : -1;
        const sortedEntries = [...entries].sort((a, b) => {
          const aTime = Number(a.getAttribute("data-archive-time") || "0");
          const bTime = Number(b.getAttribute("data-archive-time") || "0");
          return direction * (aTime - bTime) || a.textContent.localeCompare(b.textContent);
        });
        for (const entry of sortedEntries) list?.append(entry);
        for (const entry of entries) {
          entry.hidden = activeMonth !== "all" && entry.getAttribute("data-month") !== activeMonth;
        }
      }

      for (const button of monthButtons) {
        button.addEventListener("click", () => {
          activeMonth = button.getAttribute("data-month-filter") || "all";
          for (const item of monthButtons) item.setAttribute("aria-pressed", String(item === button));
          updateArchive();
        });
      }
      for (const button of sortButtons) {
        button.addEventListener("click", () => {
          activeSort = button.getAttribute("data-sort") || "newest";
          for (const item of sortButtons) item.setAttribute("aria-pressed", String(item === button));
          updateArchive();
        });
      }
    </script>
  </body>
</html>
